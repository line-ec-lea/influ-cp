{
  "folders": [
    {
      "path": ".",
    },
    {
      "path": "./apps/web",
    },
    {
      "path": "./packages/ui",
    },
  ],
  "settings": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "biomejs.biome",
    "editor.codeActionsOnSave": {
      "source.organizeImports.biome": "explicit",
      "source.fixAll": "explicit",
    },
    "extensions.ignoreRecommendations": true,
    "files.associations": {
      ".env.local": "dotenv",
    },
    "cSpell.words": [
      "clsx",
      "dotfiles",
      "lucide",
      "nextjs",
      "openai",
      "remeda",
      "shadcn",
      "tailwindcss",
    ],
  },
}
